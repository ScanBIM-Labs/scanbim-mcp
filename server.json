{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.scanbimlabs/scanbim",
  "description": "Unified AEC tools: ACC, Revit, Navisworks, Twinmotion, and APS from one endpoint.",
  "version": "1.0.5",
  "repository": {
    "url": "https://github.com/ScanBIM-Labs/scanbim-mcp",
    "source": "github"
  },
  "homepage": "https://scanbimlabs.io/mcp",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.scanbimlabs.io/unified",
      "headers": [
        {
          "name": "Authorization",
          "description": "Bearer <ScanBIM API key>",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}